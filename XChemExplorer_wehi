#!/bin/bash
# XChemExplorer launch script for WEHI Milton HPC
#
# Prerequisites:
#   1. Build the container image (once, from the repository root):
#        apptainer build xce_wehi.sif Singularity.def
#   2. CCP4 must be available on the HPC filesystem (see CCP4 section below).
#   3. PHENIX is optional but recommended (see PHENIX section below).
#   4. MOGUL requires a CCDC licence (see MOGUL section below).
#
# Software resolved at runtime
# ----------------------------
# The tools checked by XCE at startup are provided as follows:
#
#   refmac5                      — CCP4 (bound from host)
#   acedrg                       — CCP4 (bound from host)
#   grade / grade2               — CCP4 (bound from host)
#   giant.create_occupancy_params— CCP4/PANDDA (bound from host)
#   gemmi                        — CCP4 7.1+ (bound from host)
#   phenix.molprobity            — PHENIX (bound from host, optional)
#   phenix.find_tls_groups       — PHENIX (bound from host, optional)
#   mmtbx.validate_ligands       — PHENIX (bound from host, optional)
#   phenix.elbow                 — PHENIX (bound from host, optional)
#   mogul                        — CCDC software (bound from host, optional)
#   qsub                         — HPC scheduler PBS compatibility layer;
#                                  on Milton (SLURM) install the
#                                  slurm-torque package or equivalent so
#                                  that a qsub wrapper is present in PATH.
unset LD_PRELOAD
export CLUSTER_USER="${CLUSTER_USER:-$USER}"
set -euo pipefail

SCRIPT_DIR=$(readlink -e "${BASH_SOURCE[0]}" | xargs dirname)
SIF="${SCRIPT_DIR}/xce_wehi.sif"

# ---------------------------------------------------------------------------
# Locate the Apptainer/Singularity runtime.
# ---------------------------------------------------------------------------
APPTAINER=$(command -v apptainer 2>/dev/null \
            || command -v singularity 2>/dev/null \
            || true)
if [[ -z "${APPTAINER}" ]]; then
    echo "ERROR: Neither 'apptainer' nor 'singularity' was found in PATH." >&2
    echo "       Load the appropriate module or install Apptainer on Milton." >&2
    exit 1
fi

if [[ ! -f "${SIF}" ]]; then
    echo "ERROR: Container image not found: ${SIF}" >&2
    echo "       Build it first with:" >&2
    echo "         apptainer build xce_wehi.sif Singularity.def" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# CCP4 — required.
# Set the CCP4 environment variable before running this script, or edit the
# default path below to match the CCP4 installation on Milton.
# Provides: refmac5, acedrg, grade, grade2, giant.create_occupancy_params,
#           gemmi (CCP4 7.1+)
# ---------------------------------------------------------------------------
: "${CCP4:=/stornext/System/data/software/rhel/base/structbio/ccp4/ccp4-7.1/}"

if [[ ! -d "${CCP4}" ]]; then
    echo "ERROR: CCP4 directory not found: ${CCP4}" >&2
    echo "       Set the CCP4 environment variable to the correct path," >&2
    echo "       e.g.: export CCP4=/path/to/ccp4" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# PHENIX — optional, but recommended.
# Set the PHENIX environment variable or edit the default path below.
# Leave unset or empty if PHENIX is not available.
# Provides: phenix.molprobity, phenix.find_tls_groups,
#           mmtbx.validate_ligands, phenix.elbow
# ---------------------------------------------------------------------------
: "${PHENIX:=/stornext/System/data/software/rhel/9/base/structbio/phenix/1.21.2-5419/}"

# ---------------------------------------------------------------------------
# MOGUL — optional, requires a CCDC licence.
# Set BDG_TOOL_MOGUL to the full path of the mogul executable before running
# this script, e.g.:
#   export BDG_TOOL_MOGUL="/path/to/ccdc-software/mogul/bin/mogul"
# ---------------------------------------------------------------------------
# export BDG_TOOL_MOGUL="/path/to/ccdc-software/mogul/bin/mogul"

# ---------------------------------------------------------------------------
# Build the Apptainer bind-mount list and the PATH visible inside the
# container.
# ---------------------------------------------------------------------------
BINDS="${CCP4}:${CCP4}"
CONTAINER_PATH="${CCP4}/bin"

if [[ -d "${PHENIX:-}" ]]; then
    BINDS="${BINDS},${PHENIX}:${PHENIX}"
    CONTAINER_PATH="${CONTAINER_PATH}:${PHENIX}/build/bin"
fi

if [[ -n "${BDG_TOOL_MOGUL:-}" ]]; then
    MOGUL_DIR=$(dirname "${BDG_TOOL_MOGUL}")
    BINDS="${BINDS},${MOGUL_DIR}:${MOGUL_DIR}"
fi

# Expose the HPC scheduler's job-submission tools (qsub/sbatch) inside the
# container.  On Milton, qsub is typically provided by the slurm-torque
# compatibility package.  Bind the directory that contains qsub so XCE can
# find it at startup.
for SCHED_DIR in /usr/local/bin /usr/bin; do
    QSUB_PATH="${SCHED_DIR}/qsub"
    if [[ -x "${QSUB_PATH}" ]]; then
        BINDS="${BINDS},${SCHED_DIR}:${SCHED_DIR}"
        CONTAINER_PATH="${CONTAINER_PATH}:${SCHED_DIR}"
        break
    fi
done

CONTAINER_PATH="${CONTAINER_PATH}:/usr/local/bin:/usr/bin:/bin"

# ---------------------------------------------------------------------------
# Assemble Apptainer arguments.
# ---------------------------------------------------------------------------
APPTAINER_ARGS=(
    "exec"
    "--bind" "${BINDS},/vast/"
    "--env" "PATH=${CONTAINER_PATH}"
    "--env" "CCP4=${CCP4}"
    "--env" "XChemExplorer_DIR=/xce"
    "--env" "PYTHONPATH=/xce${PYTHONPATH:+:${PYTHONPATH}}"
)

if [[ -d "${PHENIX:-}" ]]; then
    APPTAINER_ARGS+=("--env" "PHENIX=${PHENIX}")
fi

if [[ -n "${BDG_TOOL_MOGUL:-}" ]]; then
    APPTAINER_ARGS+=("--env" "BDG_TOOL_MOGUL=${BDG_TOOL_MOGUL}")
fi

APPTAINER_ARGS+=("${SIF}" "${CCP4}/bin/ccp4-python" \
    "-c" "import sys; sys.path.insert(0, '/xce'); import runpy; runpy.run_module('xce', run_name='__main__')")

# ---------------------------------------------------------------------------
# Launch XChemExplorer inside the container.
# ---------------------------------------------------------------------------
exec "${APPTAINER}" "${APPTAINER_ARGS[@]}" "$@"
