# Apptainer/Singularity container definition for XChemExplorer on WEHI Milton HPC.
#
# CCP4 and PHENIX are NOT bundled in this image; they are bind-mounted from
# the HPC filesystem at runtime by the XChemExplorer_wehi launch script.
#
# Build (from the repository root):
#   apptainer build xce_wehi.sif Singularity.def
#
# Run via the provided launch script:
#   ./XChemExplorer_wehi

Bootstrap: docker
From: rockylinux:9

%labels
    org.opencontainers.image.title "XChemExplorer"
    org.opencontainers.image.description "XChemExplorer for WEHI Milton HPC — CCP4/PHENIX sourced from the host"

%post
    dnf update -y \
    && dnf install -y \
        libXrender fontconfig libXext \
        glib2 libSM libXi libXrandr libXfixes libXcursor libXinerama \
        libgomp libXdamage libxcb \
        munge \
        libyaml \
        json-c \
        http-parser \
        lua-libs \
        lz4-libs \
        libcurl \
    && dnf clean all

# Copy XChemExplorer source into the container.
# The container uses ccp4-python from the host-mounted CCP4 installation, so
# no package compilation or egg build is required here.
%files
    xce /xce/xce
    coot /xce/coot
    launch.py /xce/launch.py
    setup.py /xce/setup.py
    setup.cfg /xce/setup.cfg

%post
    # Remove any stale Python 2 bytecode so the updated .py sources are used.
    find /xce -name '*.pyc' -delete

%environment
    # Allow Qt to work without shared memory (required for some X11 setups)
    export QT_X11_NO_MITSHM=1
    # Tell XChemExplorer where its own files live inside the container
    export XChemExplorer_DIR=/xce
    # Make the xce Python package importable by ccp4-python from the host
    export PYTHONPATH=/xce${PYTHONPATH:+:${PYTHONPATH}}


%runscript
    exec "$@"
